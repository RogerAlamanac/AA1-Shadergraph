    "m_FunctionName": "HexMask",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float2 p = UV;\r\n\r\np.x = p.x * 1.15470053838;\r\np.y = p.y + fmod(floor(p.x), 2.0) * 0.5;\r\n\r\nfloat2 gv = frac(p) - 0.5;\r\ngv = abs(gv);\r\n\r\nfloat d1 = dot(gv, normalize(float2(1.0, 1.7320508)));\r\nfloat d2 = gv.x;\r\nfloat d3 = dot(gv, normalize(float2(-1.0, 1.7320508)));\r\n\r\nfloat hexDist = max(d2, max(d1, d3));\r\n\r\nfloat hexLineMask = 1.0 - smoothstep(LineWidth, LineWidth + Softness, abs(hexDist - 0.5));\r\n\r\nOut = saturate(hexLineMask);"
}

